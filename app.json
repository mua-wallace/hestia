{
  "expo": {
    "name": "Hestia",
    "slug": "hestia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/app/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#e4eefe"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hestia.app",
      "icon": "./assets/app/icon.png",
      "backgroundColor": "#e4eefe",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "icon": "./assets/app/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.hestia.app",
      "splash": {
        "image": "./assets/app/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#e4eefe"
      },
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "favicon": "./assets/app/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "812d1d0f-dd1e-4634-9ebc-c3a124ab1aa5"
      }
    },
    "owner": "wallice-dev",
    "plugins": ["expo-font"]
  }
}
